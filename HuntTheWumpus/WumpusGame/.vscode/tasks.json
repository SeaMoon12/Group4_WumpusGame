{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "cppbuild",
      "label": "Build Wumpus (Mac)",
      "command": "/usr/bin/clang++",
      "args": [
        "-std=c++17",
        "-g",
        "${workspaceFolder}/src/*.cpp",
        "-I${workspaceFolder}/include",
        "-o",
        "${workspaceFolder}/assets/WumpusGameBin"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
